{
  "info": {
    "name": "ECommerceIntegrationTests",
    "_postman_id": "ecommerce-tests-001",
    "description": "Integration test collection for Users, Payments, and Orders Web APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Users API",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "url": "{{baseUrlUsers}}/api/users"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response is an array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"Alice\", \"email\": \"alice@example.com\"}"
            },
            "url": "{{baseUrlUsers}}/api/users"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('User created successfully', () => pm.response.to.have.status(201));",
                  "const jsonData = pm.response.json();",
                  "pm.environment.set('userId', jsonData.id);",
                  "pm.test('User ID saved', () => pm.expect(pm.environment.get('userId')).to.exist);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrlUsers}}/api/users/{{userId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "const jsonData = pm.response.json();",
                  "pm.test('Correct user returned', () => pm.expect(jsonData.id).to.eql(Number(pm.environment.get('userId'))));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Payments API",
      "item": [
        {
          "name": "Get All Payments",
          "request": {
            "method": "GET",
            "url": "{{baseUrlPayments}}/api/payments"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response is an array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Payment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"userId\": \"{{userId}}\", \"amount\": 200.0}"
            },
            "url": "{{baseUrlPayments}}/api/payments"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Payment created successfully', () => pm.response.to.have.status(201));",
                  "const payment = pm.response.json();",
                  "pm.environment.set('paymentId', payment.id);",
                  "pm.test('Payment ID saved', () => pm.expect(pm.environment.get('paymentId')).to.exist);",
                  "pm.test('Payment should be successful', () => pm.expect(payment.status).to.eql('Success'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Payment by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrlPayments}}/api/payments/{{paymentId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "const jsonData = pm.response.json();",
                  "pm.test('Correct payment returned', () => pm.expect(jsonData.id).to.eql(Number(pm.environment.get('paymentId'))));"
                ]
              }
            }
          ]
        },
        {
          "name": "Check Payment Status",
          "request": {
            "method": "GET",
            "url": "{{baseUrlPayments}}/api/payments/{{paymentId}}/status"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status endpoint works', () => pm.response.to.have.status(200));",
                  "const status = pm.response.json();",
                  "pm.test('Payment should be successful', () => pm.expect(status.success).to.be.true);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Orders API",
      "item": [
        {
          "name": "Get All Orders",
          "request": {
            "method": "GET",
            "url": "{{baseUrlOrders}}/api/orders"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response is an array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"userId\": \"{{userId}}\", \"paymentId\": \"{{paymentId}}\", \"total\": 200.0}"
            },
            "url": "{{baseUrlOrders}}/api/orders"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Order created successfully', () => pm.response.to.have.status(201));",
                  "const order = pm.response.json();",
                  "pm.environment.set('orderId', order.id);",
                  "pm.test('Order ID saved', () => pm.expect(pm.environment.get('orderId')).to.exist);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Order by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrlOrders}}/api/orders/{{orderId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "const jsonData = pm.response.json();",
                  "pm.test('Order belongs to correct user', () => pm.expect(jsonData.userId).to.eql(Number(pm.environment.get('userId'))));"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}